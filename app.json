{
  "expo": {
    "name": "Kaarya-Siddhi",
    "slug": "Kaarya-Siddhi",
    "scheme": "kaaryasiddhi",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.pshlok.KaaryaSiddhi"
    },
    "web": {
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "@react-native-community/datetimepicker",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo-transparent.png",
          "imageWidth": 140,
          "resizeMode": "contain",
          "backgroundColor": "#1A2744"
        }
      ]
    ]
  }
}
